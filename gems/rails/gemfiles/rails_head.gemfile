# frozen_string_literal: true

source "https://rubygems.org", cooldown: 3

gem "julewire-core", path: "../../core"
gem "julewire-rack", path: "../../rack"
gem "julewire-rails_support", path: "../../rails_support"
gem "rails", git: "https://github.com/rails/rails.git", branch: "main"
gem "sqlite3", ">= 2.1"
gem "irb"
gem "rake", ">= 13.4"
gem "bundler-audit", ">= 0.9"
gem "debride", ">= 1.15"
gem "flay", ">= 2.14"
gem "minitest", ">= 6.0"
gem "mutant-minitest", ">= 0.16"
gem "rubocop", ">= 1.87"
gem "rubocop-minitest", ">= 0.39"
gem "rubocop-performance", ">= 1.26"
gem "rubocop-rake", ">= 0.7"
gem "simplecov", ">= 0.22"
gem "simplecov-lcov", ">= 0.9"

gemspec path: "../"
